@page "{id:int}"
@model OtoparkApp.Pages.Tarife.DeleteModel
@{
    ViewData["Title"] = "Tarife Sil";
}

<h2 class="mb-3">Tarife Sil</h2>

@if (Model.Tarife != null)
{
    <div class="alert alert-danger">
        <strong>@Model.Tarife.AracTipi</strong> tarifesini silmek istediğinize emin misiniz?
    </div>

    <div class="card mb-3" style="max-width:400px">
        <div class="card-body">
            <p><strong>Araç Tipi:</strong> @Model.Tarife.AracTipi</p>
            <p><strong>0-1 Saat:</strong> @Model.Tarife.IlkSaatUcret ₺</p>
            <p><strong>1-3 Saat/saat:</strong> @Model.Tarife.OrtaSaatUcret ₺</p>
            <p><strong>3+ Saat/saat:</strong> @Model.Tarife.UzunSaatUcret ₺</p>
        </div>
    </div>

    <form method="post">
        <button type="submit" class="btn btn-danger">Evet, Sil</button>
        <a class="btn btn-secondary" asp-page="/Tarife/Index">İptal</a>
    </form>
}
